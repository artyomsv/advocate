{
  "name": "@advocate/app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Advocate — social promotion application",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/dev.ts",
    "start": "node dist/server/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "db:generate": "tsx node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "drizzle-kit migrate",
    "db:apply": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@advocate/engine": "workspace:*",
    "@anthropic-ai/sdk": "^0.89.0",
    "@fastify/jwt": "^9.0.0",
    "@google/generative-ai": "^0.24.1",
    "bullmq": "^5.0.0",
    "drizzle-orm": "^0.36.0",
    "fastify": "^5.0.0",
    "get-jwks": "^11.0.3",
    "grammy": "^1.28.0",
    "ioredis": "^5.10.1",
    "jose": "^6.2.2",
    "openai": "^6.34.0",
    "pg": "^8.13.0",
    "pino": "^9.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.28.0",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
