# ============================================
# Mynah — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.

# --- Node ---
NODE_ENV=development

# --- Ports (host-side, 364xx range) ---
API_PORT=36401
DASHBOARD_PORT=36400
POSTGRES_PORT=36432
REDIS_PORT=36479
BULL_BOARD_PORT=36473

# --- Database ---
# Host form — used by host-running app connecting to Docker Postgres
DATABASE_URL=postgresql://mynah:mynah@localhost:36432/mynah

# --- Redis ---
REDIS_URL=redis://localhost:36479

# --- LLM Providers ---
# At least one of these is required for the system to function.
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=

# --- LLM Budget ---
# Monthly budget cap in cents. Default: 2000 ($20/month)
LLM_MONTHLY_BUDGET_CENTS=2000
# Routing mode: primary | balanced | budget
LLM_DEFAULT_MODE=balanced

# --- Keycloak (shared instance — realm imported from monorepo/auth/realms/mynah-realm.json) ---
KEYCLOAK_URL=http://localhost:9080
KEYCLOAK_REALM=mynah
KEYCLOAK_CLIENT_ID=mynah-dashboard
# Dev-only: treat every request as ROLE_ADMIN. Refused in production at boot.
AUTH_DEV_BYPASS=false

# --- Telegram ---
# Bot token from @BotFather — placeholder until bot is created
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# --- Security ---
# 32-byte hex string for AES-256-GCM credential encryption.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIAL_MASTER_KEY=

# --- Logging ---
LOG_LEVEL=info
